[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://addons/livestream-rust/bin/debug/liblivestream_rust.so"
linux.release.x86_64 =   "res://addons/livestream-rust/bin/release/liblivestream_rust.so"
windows.debug.x86_64 =   "res://addons/livestream-rust/bin/debug/livestream_rust.dll"
windows.release.x86_64 = "res://addons/livestream-rust/bin/release/livestream_rust.dll"
macos.debug =            "res://addons/livestream-rust/bin/debug/liblivestream_rust.dylib"
macos.release =          "res://addons/livestream-rust/bin/release/liblivestream_rust.dylib"
macos.debug.arm64 =      "res://addons/livestream-rust/bin/debug/liblivestream_rust.dylib"
macos.release.arm64 =    "res://addons/livestream-rust/bin/release/liblivestream_rust.dylib"
web.debug.wasm32 =       "res://addons/livestream-rust/bin/wasm32-unknown-emscripten/debug/livestream_rust.wasm"
web.release.wasm32 =     "res://addons/livestream-rust/bin/wasm32-unknown-emscripten/release/livestream_rust.wasm"
